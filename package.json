{
  "name": "ppc-dashboard-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm --workspace frontend run dev --",
    "dev:frontend": "npm --workspace frontend run dev --",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build && npm --workspace backend run build",
    "lint": "npm --workspace frontend run lint && npm --workspace backend run lint",
    "test:e2e": "npm --workspace frontend run test:e2e",
    "start:backend": "npm --workspace backend run start",
    "start:frontend": "npm --workspace frontend run start"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.1",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
